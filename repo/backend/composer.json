{
    "name": "ridecircle/backend",
    "description": "RideCircle Carpool Marketplace API",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "topthink/framework": "^6.1",
        "topthink/think-orm": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app/"
        },
        "files": [
            "app/common.php"
